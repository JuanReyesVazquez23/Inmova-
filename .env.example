# ─── COPY THIS FILE TO .env (NEVER COMMIT .env) ───────────────────────────────

# Flask
SECRET_KEY=change_this_to_a_random_64_char_string
FLASK_ENV=production

# PostgreSQL (Railway provides this automatically as DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Admin credentials (set these in Railway environment variables)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourStrongPassword123!

# CORS – add your Railway frontend domain here
ALLOWED_ORIGINS=https://your-frontend.up.railway.app,http://localhost:5173
